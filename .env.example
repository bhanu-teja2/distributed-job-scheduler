APP_ENV=local
API_PORT=8080
WORKER_CONCURRENCY=5
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_BATCH_SIZE=10

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=scheduler
POSTGRES_PASSWORD=scheduler
POSTGRES_DB=scheduler_db
POSTGRES_SSL_MODE=disable

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

KAFKA_BROKERS=localhost:9092
KAFKA_EVENTS_TOPIC=scheduler.events

JOB_LOCK_TTL_SECONDS=360
WORKER_HEARTBEAT_TTL_SECONDS=30
WORKER_HEARTBEAT_INTERVAL_SECONDS=10
JOB_DEFAULT_TIMEOUT_SECONDS=300
JOB_DEFAULT_MAX_RETRIES=3
JOB_DEFAULT_BACKOFF_SECONDS=30

LOG_LEVEL=debug
AUTH_ENABLED=true
DEV_API_KEY=djs_local_development_key_change_me
RATE_LIMIT_PER_MINUTE=120
CORS_ALLOWED_ORIGINS=http://localhost:3000
EVENT_RELAY_BATCH_SIZE=100
EVENT_RELAY_POLL_INTERVAL_SECONDS=1
EVENT_RELAY_HEALTH_PORT=8091
WORKER_HEALTH_PORT=8090
WEBHOOK_ALLOWED_HOSTS=webhook-sink
WEBHOOK_ALLOW_PRIVATE=false
