FROM golang:1.26.4-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/worker ./cmd/worker

FROM alpine:3.20
RUN addgroup -S scheduler && adduser -S -G scheduler scheduler
WORKDIR /app
COPY --from=build /out/worker /app/worker
USER scheduler
EXPOSE 8090
ENTRYPOINT ["/app/worker"]
