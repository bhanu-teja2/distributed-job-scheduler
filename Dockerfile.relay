FROM golang:1.26.5-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/event-relay ./cmd/event-relay

FROM alpine:3.20
RUN addgroup -S scheduler && adduser -S -G scheduler scheduler
WORKDIR /app
COPY --from=build /out/event-relay /app/event-relay
USER scheduler
EXPOSE 8091
ENTRYPOINT ["/app/event-relay"]
